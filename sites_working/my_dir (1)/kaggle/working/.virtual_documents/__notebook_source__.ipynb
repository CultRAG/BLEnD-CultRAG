# ============================================================================
# MULTI-GPU SAFE MODEL LOADING (4-bit Quantization) — FORCE BOTH GPUs
# - Uses Transformers + bitsandbytes (4-bit NF4)
# - Forces sharding across GPU0 + GPU1 via device_map strategy + max_memory
# - Fixes input placement for sharded models (do NOT use .to(model.device))
# ============================================================================

import torch
from huggingface_hub import login
from transformers import AutoTokenizer, AutoModelForCausalLM, BitsAndBytesConfig

MODEL_ID = "meta-llama/Llama-3.1-8B-Instruct"
HF_TOKEN  = "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"

# ----------------------------
# 0) Quick GPU sanity
# ----------------------------
assert torch.cuda.is_available(), "CUDA not available."
print(f"✅ CUDA available. GPUs detected: {torch.cuda.device_count()}")  # should be 2

# ----------------------------
# 1) LOGIN (do once)
# ----------------------------
login(token=HF_TOKEN)
print("✅ Logged in to Hugging Face")

# Optional: memory stats before load
torch.cuda.reset_peak_memory_stats()
print(f"Current GPU peak allocated: {torch.cuda.max_memory_allocated()/1e9:.2f} GB")
print(f"Allocated now: {torch.cuda.memory_allocated()/1e9:.2f} GB")
print(f"Reserved now:  {torch.cuda.memory_reserved()/1e9:.2f} GB")

# ----------------------------
# 2) 4-BIT QUANT CONFIG
# ----------------------------
print("🤖 Loading Llama-3.1-8B-Instruct with 4-bit NF4 quantization...")

quant_config = BitsAndBytesConfig(
    load_in_4bit=True,
    bnb_4bit_use_double_quant=True,   # nested quantization
    bnb_4bit_quant_type="nf4",
    bnb_4bit_compute_dtype=torch.float16,
)

# ----------------------------
# 3) TOKENIZER
# ----------------------------
tokenizer = AutoTokenizer.from_pretrained(
    MODEL_ID,
    token=HF_TOKEN,
)

# ----------------------------
# 4) FORCE MULTI-GPU SHARDING
# ----------------------------
# Key point: device_map="auto" may keep everything on cuda:0 if it fits.
# So we constrain GPU0 with max_memory and use a balanced sharding strategy.
#
# Tune these numbers if needed (T4 is usually ~15-16GiB). The point is to make
# GPU0 "too small" for the whole model so some layers must go to GPU1.

max_memory = {
    0: "9GiB",    # force spill to GPU1
    1: "14GiB",
}

model = AutoModelForCausalLM.from_pretrained(
    MODEL_ID,
    quantization_config=quant_config,
    device_map="balanced_low_0",      # spreads layers and leaves headroom on GPU0
    max_memory=max_memory,            # forces multi-GPU placement
    torch_dtype=torch.float16,
    low_cpu_mem_usage=True,
    token=HF_TOKEN,
)

# ----------------------------
# 5) PAD TOKEN SETUP
# ----------------------------
if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token
model.config.pad_token_id = tokenizer.eos_token_id

print("✅ Model loaded (4-bit).")
print(f"   hf_device_map exists: {hasattr(model, 'hf_device_map')}")
print(f"   Unique devices used: {set(model.hf_device_map.values())}")




