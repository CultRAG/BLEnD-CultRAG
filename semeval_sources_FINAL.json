  "usage_notes": {
    "primary_strategy": "Use Wikipedia for 90% of queries, add WikiVoyage for food/culture subjective questions",
    "wikidata_use_case": "Only for structured facts if you implement SPARQL (optional)",
    "dont_waste_time_on": "CIA Factbook (no API), UNESCO (limited), Ethnologue (requires paid API), country portals (no search)",
    "expected_accuracy": {
