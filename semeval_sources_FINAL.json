{
  "metadata": {
    "version": "4.0_PRODUCTION",
    "date": "2026-01-25",
    "description": "Only verified working sources with real APIs - NO hallucinations",
    "total_sources": 3,
    "all_tested": true
  },

  "knowledge_sources": [
    {
      "source_id": "wiki_en",
      "name": "Wikipedia English",
      "type": "mediawiki_api",
      "tier": 1,
      "api_details": {
        "base_url": "https://en.wikipedia.org/w/api.php",
        "auth": "none",
        "rate_limit": 50,
        "rate_unit": "requests_per_second",
        "docs": "https://www.mediawiki.org/wiki/API:Main_page"
      },
      "operations": {
        "search_titles": {
          "params": {
            "action": "opensearch",
            "search": "{query}",
            "limit": "{limit}",
            "format": "json",
            "namespace": "0"
          },
          "response_format": "[query_string, [titles], [descriptions], [urls]]",
          "example": "https://en.wikipedia.org/w/api.php?action=opensearch&search=Ireland%20sports&limit=3&format=json"
        },
        "get_extract": {
          "params": {
            "action": "query",
            "format": "json",
            "titles": "{title}",
            "prop": "extracts",
            "exintro": "true",
            "explaintext": "true",
            "redirects": "1"
          },
          "response_format": "{'query': {'pages': {'123': {'extract': 'text...'}}}}",
          "example": "https://en.wikipedia.org/w/api.php?action=query&titles=Gaelic_football&prop=extracts&exintro=true&explaintext=true&format=json"
        }
      },
      "best_for": ["geography", "history", "government", "sports", "culture", "food", "language", "education", "economy"],
      "trust_scores": {
        "geography": 0.90,
        "history": 0.85,
        "government": 0.82,
        "sports": 0.88,
        "food": 0.70,
        "culture": 0.75,
        "language": 0.85,
        "education": 0.80,
        "social_norms": 0.65
      }
    },

    {
      "source_id": "wikivoyage_en",
      "name": "WikiVoyage English",
      "type": "mediawiki_api",
      "tier": 2,
      "api_details": {
        "base_url": "https://en.wikivoyage.org/w/api.php",
        "auth": "none",
        "rate_limit": 50,
        "rate_unit": "requests_per_second",
        "docs": "https://en.wikivoyage.org/wiki/Wikivoyage:API"
      },
      "operations": {
        "search_titles": {
          "params": {
            "action": "opensearch",
            "search": "{query}",
            "limit": "{limit}",
            "format": "json"
          },
          "response_format": "[query_string, [titles], [descriptions], [urls]]",
          "example": "https://en.wikivoyage.org/w/api.php?action=opensearch&search=Ireland&limit=3&format=json"
        },
        "get_extract": {
          "params": {
            "action": "query",
            "format": "json",
            "titles": "{title}",
            "prop": "extracts",
            "explaintext": "true"
          },
          "response_format": "{'query': {'pages': {'123': {'extract': 'text...'}}}}",
          "example": "https://en.wikivoyage.org/w/api.php?action=query&titles=Ireland&prop=extracts&explaintext=true&format=json"
        }
      },
      "best_for": ["food", "culture", "social_norms", "travel"],
      "trust_scores": {
        "food": 0.75,
        "culture": 0.70,
        "social_norms": 0.65,
        "geography": 0.50
      },
      "notes": "Better for subjective cultural content (what locals eat, customs) than Wikipedia"
    },

    {
      "source_id": "wikidata",
      "name": "Wikidata Knowledge Graph",
      "type": "sparql_endpoint",
      "tier": 1,
      "api_details": {
        "sparql_endpoint": "https://query.wikidata.org/sparql",
        "entity_search": "https://www.wikidata.org/w/api.php",
        "auth": "none",
        "query_timeout": 60,
        "rate_limit": null,
        "docs": "https://www.wikidata.org/wiki/Wikidata:SPARQL_query_service"
      },
      "operations": {
        "entity_search": {
          "params": {
            "action": "wbsearchentities",
            "search": "{query}",
            "language": "en",
            "format": "json",
            "limit": "{limit}"
          },
          "response_format": "{'search': [{'id': 'Q123', 'label': 'Ireland', 'description': '...'}]}",
          "example": "https://www.wikidata.org/w/api.php?action=wbsearchentities&search=Ireland&language=en&format=json&limit=5"
        },
        "sparql_query": {
          "params": {
            "query": "{sparql_query}",
            "format": "json"
          },
          "response_format": "{'results': {'bindings': [{'var': {'value': '...'}}]}}",
          "example_query": "SELECT ?capital ?capitalLabel WHERE { wd:Q27 wdt:P36 ?capital. SERVICE wikibase:label { bd:serviceParam wikibase:language 'en'. } }"
        }
      },
      "best_for": ["geography", "government", "economy", "demographics", "structured_facts"],
      "trust_scores": {
        "geography": 0.95,
        "government": 0.88,
        "economy": 0.92,
        "demographics": 0.90,
        "food": 0.50,
        "social_norms": 0.40
      },
      "notes": "Requires SPARQL knowledge. Best for factual queries, poor for subjective/cultural questions.",
      "complexity": "high"
    }
  ],

