print("="*70)
print("KB_CHUNKS COUNTRY DIAGNOSTIC")
print("="*70)

# ────────────────────────────────────────────────────────────────────────────
# BASIC STATS
# ────────────────────────────────────────────────────────────────────────────

print(f"\n📊 Basic Statistics:")
